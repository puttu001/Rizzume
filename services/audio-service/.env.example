SERVICE_NAME=audio-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# Hosted Redis for local dev/testing. Isolation from other services' Celery
# traffic on this same instance comes from the queue name
# (app/worker/celery_app.py's task_default_queue), not the DB index —
# numbered DBs don't work against a hosted instance (confirmed live).
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

OPENAI_API_KEY=${OPENAI_API_KEY}

AZURE_CONNECTION_STRING=${AZURE_CONNECTION_STRING}
AZURE_CONTAINER_NAME=rizzume-audio
