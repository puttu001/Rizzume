SERVICE_NAME=api-gateway
ENVIRONMENT=local
LOG_LEVEL=INFO

# Must match JWT_SECRET in auth-service/.env exactly — the gateway verifies
# tokens that auth-service issues.
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256

CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# These target plain `uv run uvicorn` local dev (each service's own port —
# see its README). docker-compose.yml overrides these to container hostnames
# on port 8000, since that's how services actually reach each other on the
# Docker network.
AUTH_SERVICE_URL=http://localhost:8001
INTERVIEW_SERVICE_URL=http://localhost:8002
AUDIO_SERVICE_URL=http://localhost:8004
REPORT_SERVICE_URL=http://localhost:8005
