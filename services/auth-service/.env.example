SERVICE_NAME=auth-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# This service's own database — no other service reads/writes auth_db.
# Neon for host-side dev/testing; swap to the local-postgres form (see
# infra/docker-compose.yml overrides) if you're running the full compose stack.
DATABASE_URL=${NEON_CONNECTION_BASE}auth_db?ssl=require

# Must match JWT_SECRET/JWT_ALGORITHM in api-gateway/.env exactly.
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
