SERVICE_NAME=auth-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# This service's own database — no other service reads/writes auth_db.
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@localhost:5432/auth_db

# Must match JWT_SECRET/JWT_ALGORITHM in api-gateway/.env exactly.
JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
