SERVICE_NAME=interview-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# This service's own database — no other service reads/writes interview_db.
DATABASE_URL=${NEON_CONNECTION_BASE}interview_db?ssl=require

# Local dev default; docker-compose.yml overrides to the container hostname.
CONVERSATION_SERVICE_URL=http://localhost:8003

OPENAI_API_KEY=${OPENAI_API_KEY}

AZURE_CONNECTION_STRING=${AZURE_CONNECTION_STRING}
AZURE_RESUME_CONTAINER_NAME=rizzume-resumes
