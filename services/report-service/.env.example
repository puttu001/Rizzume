SERVICE_NAME=report-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# This service's own database — no other service reads/writes report_db.
DATABASE_URL=${NEON_CONNECTION_BASE}report_db?ssl=require

# Redis DB index 1 reserved for this service's Celery broker/results.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=rizzume-reports
OBJECT_STORAGE_ACCESS_KEY=${OBJECT_STORAGE_ACCESS_KEY}
OBJECT_STORAGE_SECRET_KEY=${OBJECT_STORAGE_SECRET_KEY}
