SERVICE_NAME=conversation-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# This service's own database — no other service reads/writes conversation_db.
DATABASE_URL=${NEON_CONNECTION_BASE}conversation_db?ssl=require

# Active-session cache. Hosted Redis for local dev/testing; docker-compose.yml
# overrides to redis://redis:6379/0 (DB index 0 reserved for this service)
# when running the full local compose stack.
REDIS_URL=${REDIS_URL}
