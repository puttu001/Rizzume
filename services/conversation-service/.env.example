SERVICE_NAME=conversation-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# This service's own database — no other service reads/writes conversation_db.
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@localhost:5432/conversation_db

# Active-session cache. DB index 0 reserved for this service — see
# infra/docker-compose.yml for how other services get their own index.
REDIS_URL=redis://localhost:6379/0
