# The ONE file you hand-edit for local dev. Copy to .env.secrets (gitignored)
# and fill in real values. scripts/bootstrap-env.sh reads this and stamps out
# every services/*/.env + frontend/.env from their .env.example templates.
#
# Rotate a key? Edit it here, rerun the script — every service picks it up.

POSTGRES_PASSWORD=devpassword

# Must be the same value everywhere it's used — see README for which
# services share which secrets.
JWT_SECRET=change-me-to-a-long-random-string

OPENAI_API_KEY=sk-replace-me

OBJECT_STORAGE_ACCESS_KEY=devaccesskey
OBJECT_STORAGE_SECRET_KEY=devsecretkey
