# The ONE file you hand-edit for local dev. Copy to .env.secrets (gitignored)
# and fill in real values. scripts/bootstrap-env.sh reads this and stamps out
# every services/*/.env + frontend/.env from their .env.example templates.
#
# Rotate a key? Edit it here, rerun the script — every service picks it up.

POSTGRES_PASSWORD=devpassword

# Neon Postgres project used for host-side local dev/testing (outside
# docker-compose, which still targets the local `postgres` container — see
# current_state.md). One Neon project, one database per service
# (auth_db/interview_db/conversation_db/report_db), same ownership rule as
# local: no service reads/writes another's database.
NEON_CONNECTION_BASE=postgresql+asyncpg://user:password@host/

# Hosted Redis (e.g. Upstash free tier) used for host-side local dev/testing,
# same reasoning as Neon above. Single instance for now — services that need
# their own Redis "index" (audio-service, report-service Celery brokers) will
# need a key-prefix scheme instead of numbered DBs once they're wired to this
# same instance, since managed Redis providers often don't support SELECT.
REDIS_URL=rediss://default:password@host:6379

# Must be the same value everywhere it's used — see README for which
# services share which secrets.
JWT_SECRET=change-me-to-a-long-random-string

OPENAI_API_KEY=sk-replace-me

# Azure Blob Storage (azure-storage-blob SDK, not S3-compatible/boto3).
# MUST be quoted — the real value contains literal semicolons, and this
# file is `source`d by bash, where unquoted `;` is a command separator.
AZURE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net"
